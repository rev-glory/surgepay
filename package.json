{
  "name": "surgepay-monorepo",
  "version": "0.0.1",
  "private": true,
  "description": "SurgePay — Production-grade distributed payment orchestration platform monorepo",
  "packageManager": "pnpm@9.0.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "turbo run format",
    "test:integration": "tsx scripts/run-integration-tests.ts",
    "test:e2e": "jest --config jest.e2e.config.js --runInBand --forceExit",
    "test": "turbo run test && pnpm test:integration",
    "clean": "turbo run clean && rimraf --glob node_modules \"apps/*/node_modules\" \"packages/*/node_modules\" \"apps/*/dist\" \"packages/*/dist\""
  },
  "devDependencies": {
    "@surgepay/common": "workspace:*",
    "@commitlint/cli": "^19.3.0",
    "@commitlint/config-conventional": "^19.2.2",
    "@nestjs/cli": "^10.4.5",
    "@nestjs/common": "^10.4.15",
    "@nestjs/core": "^10.4.15",
    "@nestjs/swagger": "^7.4.2",
    "@nestjs/testing": "^10.4.15",
    "@prisma/client": "^5.15.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.7.5",
    "@types/supertest": "^7.2.0",
    "eslint": "^9.14.0",
    "eslint-config-prettier": "^9.1.0",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "husky": "^9.0.11",
    "ioredis": "^5.4.1",
    "jest": "^30.4.2",
    "kafkajs": "^2.2.4",
    "prettier": "^3.3.3",
    "prisma": "^5.15.0",
    "rimraf": "^6.0.1",
    "supertest": "^7.2.2",
    "swagger-ui-express": "^5.0.1",
    "testcontainers": "^12.0.4",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsx": "^4.19.1",
    "turbo": "^2.1.3",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.13.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "pnpm": {
    "overrides": {
      "undici": "^6.21.1"
    }
  }
}
