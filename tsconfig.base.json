{
  "$schema": "https://json.schemastore.org/tsconfig",
  "compilerOptions": {
    "target": "ES2022",
    "module": "CommonJS",
    "moduleResolution": "node",
    "lib": ["ES2022"],
    "declaration": true,
    "removeComments": false,
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "allowSyntheticDefaultImports": true,
    "sourceMap": true,
    "incremental": true,
    "skipLibCheck": true,
    "strict": true,
    "strictPropertyInitialization": true,
    "noUncheckedIndexedAccess": true,
    "noImplicitOverride": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictBindCallApply": true,
    "forceConsistentCasingInFileNames": true,
    "noFallthroughCasesInSwitch": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "resolveJsonModule": true,
    "baseUrl": "./",
    "paths": {
      "@common": ["packages/common/src"],
      "@common/*": ["packages/common/src/*"],
      "@surgepay/common": ["packages/common/src"],
      "@surgepay/common/*": ["packages/common/src/*"],
      "@contracts": ["packages/contracts/src"],
      "@contracts/*": ["packages/contracts/src/*"],
      "@surgepay/contracts": ["packages/contracts/src"],
      "@surgepay/contracts/*": ["packages/contracts/src/*"],
      "@events": ["packages/events/src"],
      "@events/*": ["packages/events/src/*"],
      "@surgepay/events": ["packages/events/src"],
      "@surgepay/events/*": ["packages/events/src/*"],
      "@config": ["packages/config/src"],
      "@config/*": ["packages/config/src/*"],
      "@surgepay/config": ["packages/config/src"],
      "@surgepay/config/*": ["packages/config/src/*"],
      "@shared": ["packages/common/src"],
      "@shared/*": ["packages/common/src/*"],
      "@database": ["packages/database/src"],
      "@database/*": ["packages/database/src/*"],
      "@surgepay/common-http": ["packages/common/http/src"],
      "@surgepay/common-http/*": ["packages/common/http/src/*"]
    }
  },
  "exclude": ["node_modules", "dist"]
}
