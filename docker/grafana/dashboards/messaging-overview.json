      "gridPos": { "h": 6, "w": 8, "x": 8, "y": 24 },
      "id": 8,
      "title": "Consumer Lag Estimate (Messages)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
