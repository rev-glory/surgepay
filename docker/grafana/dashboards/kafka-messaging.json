{
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "datasource", "uid": "grafana" },
        "enable": true,
        "hide": true,
        "name": "Annotations & Alerts",
        "type": "dashboard"
      }
    ]
  },
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "liveNow": false,
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "id": 1,
      "title": "Messages Published Rate (by Event Type)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "sum(rate(events_published_total[1m])) by (eventType)",
          "legendFormat": "{{eventType}}",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth" },
          "unit": "pps"
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "id": 2,
      "title": "Messages Consumed Rate (by Consumer Group)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "sum(rate(events_consumed_total[1m])) by (consumer, eventType)",
          "legendFormat": "{{consumer}} - {{eventType}}",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth" },
          "unit": "pps"
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "id": 3,
      "title": "Producer Latency (Average ms)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "sum(rate(publish_duration_ms_sum[5m])) by (eventType) / sum(rate(publish_duration_ms_count[5m])) by (eventType)",
          "legendFormat": "{{eventType}}",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth" },
          "unit": "ms"
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "id": 4,
      "title": "Publish Success Rate vs failure Rate (ratio)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "sum(rate(events_published_total[1m])) by (service)",
          "legendFormat": "Successes ({{service}})",
          "range": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "sum(rate(publish_failures_total[1m])) by (service)",
          "legendFormat": "Failures ({{service}})",
          "range": true,
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line" },
          "unit": "pps"
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "id": 5,
      "title": "Kafka Topic Throughput (Total Msg Rate)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "sum(rate(events_published_total[1m]))",
          "legendFormat": "Total Message Ingestion Rate",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth" },
          "unit": "pps"
        }
      }
    },
    {
      "collapsed": false,
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "id": 6,
      "title": "Publish Success Percentage (%)",
      "type": "gauge",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "sum(rate(events_published_total[1m])) / (sum(rate(events_published_total[1m])) + sum(rate(publish_failures_total[1m])) + 0.0001) * 100",
          "legendFormat": "Success %",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 95 },
              { "color": "green", "value": 99 }
            ]
          }
        }
      }
    }
  ],
  "refresh": "5s",
  "schemaVersion": 39,
  "style": "dark",
  "tags": ["surgepay", "kafka"],
  "time": {
    "from": "now-15m",
    "to": "now"
  },
  "timepicker": {},
  "timezone": "utc",
  "title": "SurgePay - Kafka Messaging Dashboard",
  "uid": "kafka-messaging",
  "version": 1,
  "weekStart": ""
}
