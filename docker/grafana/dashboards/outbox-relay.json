      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.95, sum(rate(outbox_relay_publish_duration_ms_bucket[5m])) by (le))",
