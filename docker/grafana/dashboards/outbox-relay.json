          "range": true,
          "refId": "A"
        },
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "histogram_quantile(0.99, sum(rate(outbox_relay_publish_duration_ms_bucket[5m])) by (le))",
          "legendFormat": "p99 publish duration",
          "range": true,
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line", "lineInterpolation": "smooth" },
