      "title": "Relay Average Batch Size (Events)",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "Prometheus" },
      "targets": [
        {
          "datasource": { "type": "prometheus", "uid": "Prometheus" },
          "editorMode": "code",
          "expr": "sum(rate(outbox_relay_batch_size_sum[5m])) / sum(rate(outbox_relay_batch_size_count[5m]))",
          "legendFormat": "Average Batch Size",
          "range": true,
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": { "drawStyle": "line" },
          "unit": "short"
        }
