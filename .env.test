# ==============================================================================
# SurgePay Local Testing Environment Variables (.env.test)
# ==============================================================================

# System Environment
NODE_ENV=test

# HTTP Service Configuration
PORT=3001
HOST=127.0.0.1
API_PREFIX=api/v1

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://surgepay_admin:surgepay_secure_pass@127.0.0.1:5432/surgepay_test_db?sslmode=disable
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=surgepay_admin
DATABASE_PASSWORD=surgepay_secure_pass
DATABASE_NAME=surgepay_test_db
DATABASE_POOL_SIZE=5
DATABASE_CONNECT_TIMEOUT=2000
DATABASE_IDLE_TIMEOUT=10000

# Redis Configuration
REDIS_URL=redis://:redis_secure_pass@127.0.0.1:6379/1
REDIS_PASSWORD=redis_secure_pass
REDIS_TLS=false

# Kafka / Redpanda Configuration
KAFKA_BROKERS=localhost:29092
KAFKA_CLIENT_ID=surgepay-test
KAFKA_SSL=false
KAFKA_SASL=false
KAFKA_CONSUMER_GROUP_ID=order-saga-orchestrator-test

# Logging Configuration
LOG_LEVEL=warn
LOG_PRETTY=true
LOG_SERVICE_NAME=surgepay-service-test

# OpenTelemetry / Telemetry Configuration
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=surgepay-service-test

# Security Configuration
JWT_SECRET=test-jwt-secret-key-very-long-and-secure-change-it-on-prod
API_KEY_HEADER=x-api-key
CORS_ENABLED=true

# Gateway Local Configurations
MERCHANT_SERVICE_URL=http://127.0.0.1:3001
MERCHANT_SERVICE_TIMEOUT=5000
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_DEFAULT_LIMIT=100

# Idempotency Service Configuration
IDEMPOTENCY_TTL_HOURS=24
IDEMPOTENCY_REDIS_PREFIX=idem
IDEMPOTENCY_CONFLICT_MODE=409
IDEMPOTENCY_SERVICE_URL=http://127.0.0.1:3002

# Outbox Relay Configuration
OUTBOX_POLLING_INTERVAL=500
OUTBOX_BATCH_SIZE=100
OUTBOX_RETRY_LIMIT=3
OUTBOX_PUBLISH_TIMEOUT=5000
OUTBOX_RETENTION_DAYS=7
OUTBOX_STALE_TIMEOUT=300000




