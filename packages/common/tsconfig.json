{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "paths": {
      "@common": ["./src"],
      "@common/*": ["./src/*"],
      "@surgepay/common": ["./src"],
      "@surgepay/common/*": ["./src/*"],
      "@shared": ["./src"],
      "@shared/*": ["./src/*"],
      "@surgepay/config": ["packages/config/dist/index"],
      "@surgepay/config/*": ["packages/config/dist/*"],
      "@surgepay/events": ["packages/events/dist/index"],
      "@surgepay/events/*": ["packages/events/dist/*"]
    }
  },
  "include": ["src/**/*"]
}
