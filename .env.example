# ==============================================================================
# SurgePay Centralized Environment Variables Template (.env.example)
# ==============================================================================
# WARNING: Do not include real secrets or credentials in this template.
# Copy this file to .env.development or .env.test and fill in local values.

# System Environment
NODE_ENV=development

# HTTP Service Configuration
PORT=3000
HOST=127.0.0.1
API_PREFIX=api/v1

# Database Configuration (PostgreSQL)
DATABASE_URL=postgresql://surgepay_admin:surgepay_secure_pass@127.0.0.1:5432/surgepay_db?sslmode=disable
DATABASE_HOST=localhost
DATABASE_PORT=5432
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_NAME=surgepay
DATABASE_POOL_SIZE=10
DATABASE_CONNECT_TIMEOUT=5000
DATABASE_IDLE_TIMEOUT=30000

# Redis Configuration
REDIS_URL=redis://[REDIS_HOST]:[REDIS_PORT]
REDIS_PASSWORD=
REDIS_TLS=false

# Kafka / Redpanda Configuration
KAFKA_BROKERS=localhost:9092
KAFKA_CLIENT_ID=surgepay
KAFKA_SSL=false
KAFKA_SASL=false

# Logging Configuration
LOG_LEVEL=info
LOG_PRETTY=false
LOG_SERVICE_NAME=surgepay-service

# OpenTelemetry / Telemetry Configuration
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=surgepay-service

# Security Configuration
JWT_SECRET=your-super-secret-jwt-key-change-me-in-production
API_KEY_HEADER=x-api-key
CORS_ENABLED=true

# Gateway Local Configurations
GATEWAY_URL=http://127.0.0.1:3000
MERCHANT_SERVICE_URL=http://127.0.0.1:3001
MERCHANT_SERVICE_TIMEOUT=5000
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_DEFAULT_LIMIT=100

# Idempotency Service Configuration
IDEMPOTENCY_TTL_HOURS=24
IDEMPOTENCY_REDIS_PREFIX=idem
IDEMPOTENCY_CONFLICT_MODE=409
IDEMPOTENCY_SERVICE_URL=http://127.0.0.1:3002

# Internal HTTP Client Configurations
PAYMENT_SERVICE_URL=http://127.0.0.1:3003
ORDER_SERVICE_URL=http://127.0.0.1:3004
LEDGER_SERVICE_URL=http://127.0.0.1:3005
BALANCE_SERVICE_URL=http://127.0.0.1:3006
NOTIFICATION_SERVICE_URL=http://127.0.0.1:3007
INTERNAL_REQUEST_TIMEOUT=2000
INTERNAL_REQUEST_RETRIES=3
INTERNAL_REQUEST_RETRY_DELAY=100

# Outbox Relay Configuration
OUTBOX_POLLING_INTERVAL=500
OUTBOX_BATCH_SIZE=100
OUTBOX_RETRY_LIMIT=3
OUTBOX_PUBLISH_TIMEOUT=5000
OUTBOX_RETENTION_DAYS=7
OUTBOX_STALE_TIMEOUT=300000

