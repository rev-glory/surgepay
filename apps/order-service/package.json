{
  "name": "@surgepay/order-service",
  "version": "0.0.1",
  "private": true,
  "scripts": {
    "prisma:generate": "prisma generate --schema=src/prisma/order.prisma",
    "build": "prisma generate --schema=src/prisma/order.prisma && nest build",
    "start": "nest start",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "typecheck": "tsc --noEmit",
    "lint": "eslint . --max-warnings 0",
    "test": "jest --config jest.config.js"
  },
  "dependencies": {
    "@nestjs/common": "^10.4.15",
    "@nestjs/config": "^3.3.0",
    "@nestjs/core": "^10.4.15",
    "@nestjs/platform-express": "^10.4.15",
    "@nestjs/terminus": "^10.2.0",
    "@database": "workspace:*",
    "@prisma/client": "^5.15.0",
    "@surgepay/common": "workspace:*",
    "@surgepay/config": "workspace:*",
    "@surgepay/contracts": "workspace:*",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.1",
    "dotenv": "^17.4.2",
    "nestjs-pino": "^4.3.0",
    "pino": "^9.6.0",
    "pino-pretty": "^13.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1"
  },
  "devDependencies": {
    "@nestjs/testing": "^10.4.15",
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.5",
    "prisma": "^5.15.0",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.6.3"
  }
}
