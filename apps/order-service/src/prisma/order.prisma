datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

enum OrderStatus {
  CREATED
  PAID
  CANCELLED
  REFUNDED
}

model Order {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  merchantId String      @db.Uuid
  amount     Int
  currency   String
  status     OrderStatus @default(CREATED)
  reference  String
  createdAt  DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime    @updatedAt @db.Timestamptz(6)

  @@unique([merchantId, reference])
  @@index([merchantId])
  @@index([status])
  @@index([createdAt])
  @@index([reference])
}

enum InboxStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  FAILED
  RETRYING
  DLQ_SENT
}

model InboxEvent {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId       String
  consumer      String
  status        InboxStatus @default(RECEIVED)
  payload       Json
  receivedAt    DateTime    @default(now()) @db.Timestamptz(6)
  processedAt   DateTime?   @db.Timestamptz(6)
  retryCount    Int         @default(0)

  // Envelope metadata stored as first-class columns
  eventType     String
  correlationId String
  causationId   String
  sagaId        String
  timestamp     DateTime    @db.Timestamptz(6)
  version       Int

  @@unique([consumer, eventId])
  @@index([eventId])
  @@index([status])
  @@index([correlationId])
  @@index([sagaId])
  @@index([receivedAt])
}

enum OrderValidationStatus {
  PENDING
  CONFIRMED
  REJECTED
}

enum SagaStatus {
  LEDGER_PENDING
  LEDGER_RECORDED
  ELIGIBILITY_PENDING
  BALANCE_PENDING
  BALANCE_RESERVED
  NOTIFICATION_PENDING
  NOTIFIED
  REVERSED
  CLOSED
}

model SagaInstance {
  id                    String                @id
  paymentId             String                @unique
  correlationId         String                @unique
  status                SagaStatus            @default(LEDGER_PENDING)
  orderValidationStatus OrderValidationStatus @default(PENDING)
  merchantId            String
  amount                Int
  currency              String
  version               Int                   @default(0)
  failureReason         String?
  failedAt              DateTime?             @db.Timestamptz(6)
  originService         String?

  stateUpdatedAt        DateTime              @default(now()) @db.Timestamptz(6)
  retryCount            Int                   @default(0)
  lastRetryAt           DateTime?             @db.Timestamptz(6)
  nextRetryAt           DateTime?             @db.Timestamptz(6)
  currentCommandId      String?
  retryHandoffAt        DateTime?             @db.Timestamptz(6)

  startedAt             DateTime              @default(now()) @db.Timestamptz(6)
  completedAt           DateTime?             @db.Timestamptz(6)
  createdAt             DateTime              @default(now()) @db.Timestamptz(6)
  updatedAt             DateTime              @updatedAt @db.Timestamptz(6)

  recoveredAt           DateTime?             @db.Timestamptz(6)
  recoveryCount         Int                   @default(0)
  recoveryReason        String?

  @@index([status])
  @@index([correlationId])
  @@index([nextRetryAt])
  @@index([retryHandoffAt])
}

enum SagaTransitionType {
  SAGA_STATUS
  ORDER_VALIDATION
  // Compensation progress checkpoints — used by CompensationCoordinator to
  // persist durable markers at each compensation step (BALANCE_REVERSAL_DISPATCHED,
  // BALANCE_REVERSAL_ACKNOWLEDGED, LEDGER_REVERSAL_DISPATCHED). These are not
  // saga status transitions; they allow crash recovery to determine which
  // compensation step was reached before the process died.
  COMPENSATION_STEP
}

model SagaTransition {
  id             String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  sagaId         String
  correlationId  String
  transitionType SagaTransitionType
  fromState      String
  toState        String
  timestamp      DateTime           @default(now()) @db.Timestamptz(6)
  eventId        String
  causationId    String
  eventType      String

  @@index([sagaId])
  @@index([correlationId])
}

enum OutboxStatus {
  PENDING
  PUBLISHING
  PUBLISHED
  FAILED
  RETRYING
}

model OrderOutboxEvent {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventType     String
  payload       Json
  status        OutboxStatus @default(PENDING)
  createdAt     DateTime     @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime     @updatedAt @db.Timestamptz(6)

  @@index([status])
}

