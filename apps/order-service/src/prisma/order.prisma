datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
  output   = "../generated/client"
}

enum OrderStatus {
  CREATED
  PAID
  CANCELLED
  REFUNDED
}

model Order {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  merchantId String      @db.Uuid
  amount     Int
  currency   String
  status     OrderStatus @default(CREATED)
  reference  String
  createdAt  DateTime    @default(now()) @db.Timestamptz(6)
  updatedAt  DateTime    @updatedAt @db.Timestamptz(6)

  @@unique([merchantId, reference])
  @@index([merchantId])
  @@index([status])
  @@index([createdAt])
  @@index([reference])
}

enum InboxStatus {
  RECEIVED
  PROCESSING
  PROCESSED
  FAILED
  RETRYING
  DLQ_SENT
}

model InboxEvent {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  eventId       String
  consumer      String
  status        InboxStatus @default(RECEIVED)
  payload       Json
  receivedAt    DateTime    @default(now()) @db.Timestamptz(6)
  processedAt   DateTime?   @db.Timestamptz(6)
  retryCount    Int         @default(0)

  // Envelope metadata stored as first-class columns
  eventType     String
  correlationId String
  causationId   String
  sagaId        String
  timestamp     DateTime    @db.Timestamptz(6)
  version       Int

  @@unique([consumer, eventId])
  @@index([eventId])
  @@index([status])
  @@index([correlationId])
  @@index([sagaId])
  @@index([receivedAt])
}

enum SagaStatus {
  LEDGER_PENDING
  LEDGER_RECORDED
  ELIGIBILITY_PENDING
  BALANCE_PENDING
  BALANCE_RESERVED
  NOTIFICATION_PENDING
  NOTIFIED
  REVERSED
  CLOSED
}

model SagaInstance {
  id            String     @id
  paymentId     String     @unique
  correlationId String     @unique
  status        SagaStatus @default(LEDGER_PENDING)
  version       Int        @default(0)

  startedAt     DateTime   @default(now()) @db.Timestamptz(6)
  completedAt   DateTime?  @db.Timestamptz(6)
  createdAt     DateTime   @default(now()) @db.Timestamptz(6)
  updatedAt     DateTime   @updatedAt @db.Timestamptz(6)

  @@index([status])
  @@index([correlationId])
}
