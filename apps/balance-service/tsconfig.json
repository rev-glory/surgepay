{
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "outDir": "./dist",
    "rootDir": "./src",
    "baseUrl": "./",
    "incremental": false,
    "paths": {
      "@surgepay/common": ["../../packages/common/dist/index"],
      "@surgepay/common/*": ["../../packages/common/dist/*"],
      "@surgepay/config": ["../../packages/config/dist/index"],
      "@surgepay/config/*": ["../../packages/config/dist/*"],
      "@surgepay/contracts": ["../../packages/contracts/dist/index"],
      "@surgepay/contracts/*": ["../../packages/contracts/dist/*"],
      "@surgepay/database": ["../../packages/database/dist/index"],
      "@surgepay/database/*": ["../../packages/database/dist/*"],
      "@surgepay/database/generated/*": ["../../packages/database/generated/*"]
    }
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}
